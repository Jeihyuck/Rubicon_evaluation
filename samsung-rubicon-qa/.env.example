# Samsung Rubicon QA - Codespaces-first environment defaults
# Copy this file to .env and fill in the required values.
# cp .env.example .env

# Required: OpenAI API Key for evaluation of real browser-captured answers only
OPENAI_API_KEY=

# Default public target. Login automation is intentionally unsupported.
SAMSUNG_BASE_URL=https://www.samsung.com/sec/

# Codespaces-first defaults: headed browser, Korean locale, trace/video on
HEADLESS=false
DEFAULT_LOCALE=ko-KR
MAX_QUESTIONS=5
OPENAI_MODEL=gpt-4o
PLAYWRIGHT_TIMEOUT_MS=30000
ANSWER_STABLE_CHECKS=3
ANSWER_STABLE_INTERVAL_SEC=1.0
ENABLE_VIDEO=true
ENABLE_TRACE=true
ENABLE_OCR_FALLBACK=false
