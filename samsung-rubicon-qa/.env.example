# Samsung Rubicon QA - Codespaces-first environment defaults
# Copy this file to .env and fill in the required values.
# cp .env.example .env

# Required: OpenAI API Key for evaluation of real browser-captured answers only
OPENAI_API_KEY=

# Default public target. Login automation is intentionally unsupported.
SAMSUNG_BASE_URL=https://www.samsung.com/sec/

# Codespaces-first defaults: headed browser, Korean locale, video/trace/ocr off
HEADLESS=false
DEFAULT_LOCALE=ko-KR
MAX_QUESTIONS=5
OPENAI_MODEL=gpt-4o
PLAYWRIGHT_TIMEOUT_MS=30000
ANSWER_STABLE_CHECKS=3
ANSWER_STABLE_INTERVAL_SEC=1.0
ENABLE_VIDEO=false
ENABLE_TRACE=false
ENABLE_OCR_FALLBACK=false
RUBICON_CHAT_DEBUG=false
RUBICON_FORCE_ACTIVATION=true
RUBICON_DISABLE_SDK=false
RUBICON_MAX_INPUT_CANDIDATES=5
RUBICON_FRAME_RESCAN_ROUNDS=3
RUBICON_OPENED_FOOTER_SCREENSHOT=true
RUBICON_BEFORE_SEND_SCREENSHOT=true
RUBICON_AFTER_ANSWER_SCREENSHOT=true
